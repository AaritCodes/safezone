# SafeZone backend runtime configuration
NODE_ENV=production
PORT=8787

# Logging
SAFEZONE_LOG_LEVEL=info
SAFEZONE_TRUST_PROXY=false

# Request limits
SAFEZONE_BODY_LIMIT=1mb
SAFEZONE_RATE_LIMIT_WINDOW_MS=60000
SAFEZONE_RATE_LIMIT_MAX_REQUESTS=120

# API authentication (comma-separated keys)
SAFEZONE_AUTH_REQUIRED=true
SAFEZONE_API_KEYS=replace-with-secure-api-key

# CORS allow-list (comma-separated). Leave empty only for local development defaults.
SAFEZONE_CORS_ORIGINS=https://your-frontend.example.com

# Metrics endpoint protection
SAFEZONE_METRICS_TOKEN=replace-with-secure-metrics-token

# Distributed tracing
SAFEZONE_TRACING_ENABLED=true

# CV inference provider
# Values: auto | remote | simulation
SAFEZONE_CV_MODE=auto
SAFEZONE_CV_ENDPOINT=
SAFEZONE_CV_API_KEY=
SAFEZONE_CV_TIMEOUT_MS=2500
SAFEZONE_CV_FALLBACK_TO_SIMULATION=true
SAFEZONE_CV_MODEL_VERSION=yolov8-sim-v1

# Alerting thresholds and delivery
SAFEZONE_ALERTING_ENABLED=false
SAFEZONE_ALERTING_WEBHOOK_URL=
SAFEZONE_ALERTING_AUTH_TOKEN=
SAFEZONE_ALERTING_WINDOW_MS=60000
SAFEZONE_ALERTING_MIN_REQUEST_COUNT=20
SAFEZONE_ALERTING_ERROR_RATE_THRESHOLD=0.05
SAFEZONE_ALERTING_P95_LATENCY_MS_THRESHOLD=800
SAFEZONE_ALERTING_COOLDOWN_MS=300000

# Model governance and drift/calibration checks
SAFEZONE_GOVERNANCE_ENABLED=true
SAFEZONE_GOVERNANCE_PSI_THRESHOLD=0.2
SAFEZONE_GOVERNANCE_MIN_DRIFT_SAMPLES=100
SAFEZONE_GOVERNANCE_BRIER_THRESHOLD=0.22
SAFEZONE_GOVERNANCE_MIN_LABELS=50
SAFEZONE_GOVERNANCE_MAX_INFERENCE_SAMPLES=5000
SAFEZONE_GOVERNANCE_MAX_LABEL_SAMPLES=2000
